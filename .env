PORT=3000

# Required for Azure Realtime + ngrok startup
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=your_realtime_deployment_name
NGROK_AUTHTOKEN=your_ngrok_auth_token

# Optional
AZURE_OPENAI_API_VERSION=2024-10-01-preview
NGROK_STATIC_URL=
AUDIOHOOK_API_KEY=
INITIAL_GREETING=Hello, how can I help you today?
OPENAI_VOICE_ID=alloy
DEFAULT_PROMPT_INSTRUCTIONS=You are a helpful voice assistant on a phone call. Keep responses concise and conversational.
NO_INPUT_MESSAGE=User did not provide any input. Act accordingly.
NO_INPUT_TIMEOUT=15000
MIN_BINARY_MESSAGE_SIZE=8000
MAX_BINARY_MESSAGE_SIZE=64000
DEBUG=false
